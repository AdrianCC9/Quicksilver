# Quicksilver local-first defaults
STORAGE_BACKEND=mysql
DATABASE_URL=mysql+pymysql://quicksilver:quicksilver@127.0.0.1:3306/quicksilver?charset=utf8mb4
SENTIMENT_BACKEND=lexicon

# Local ingestion
PUBLIC_NEWS_ENABLED=true
POLITICAL_NEWS_ENABLED=true
PUBLIC_NEWS_MAX_TICKERS=100
PUBLIC_NEWS_MAX_ITEMS_PER_FEED=8
PUBLIC_NEWS_TIMEOUT_SECONDS=8
LOOKBACK_DAYS=3
POLLING_INTERVAL_MINUTES=60

# Portfolio simulation
PORTFOLIO_INITIAL_CASH_CAD=5000
PORTFOLIO_RUN_NAME=default
PORTFOLIO_MAX_POSITIONS=5
PORTFOLIO_CASH_RESERVE_PCT=0.05
USD_TO_CAD_RATE=1.37

# Optional live price providers
PRICE_PROVIDER_ORDER=polygon,alpha_vantage,yahoo,stooq
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Optional Finnhub ingestion
FINNHUB_ENABLED=false
FINNHUB_API_KEY=

# Optional FinBERT backend
FINBERT_MODEL_NAME=ProsusAI/finbert
FINBERT_BATCH_SIZE=64

# Dashboard modes
DASHBOARD_DEMO_MODE=false

# Local health alerts
HEALTH_MIN_RAW_HEADLINES_PER_RUN=50
HEALTH_MIN_INSIGHTS_PER_RUN=10
HEALTH_MAX_SYNTHETIC_EVALUATION_PCT=35
HEALTH_STALE_RUN_HOURS=3
LOCAL_HEALTH_NOTIFICATIONS_ENABLED=false

# Optional Slack/email notifications
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
EMAIL_ENABLED=false
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Optional Snowflake/Kafka/dbt/Airflow path
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
KAFKA_BROKER=127.0.0.1:9092
RAW_HEADLINES_TOPIC=raw_headlines
SCORED_HEADLINES_TOPIC=scored_headlines
SENTIMENT_CONSUMER_GROUP_ID=sentiment-scorers
